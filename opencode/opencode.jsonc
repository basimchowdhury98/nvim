{
    "$schema": "https://opencode.ai/config.json",
    "compaction": {
        "auto": false,
        "prune": true,
        "reserved": 10000
    },
    "default_agent": "plan",
    "agent": {
        "plan": {
            "color": "#12a61c"
        },
        "build": {
            "color": "#bf3d55"
        }
    },
    "mcp": {
        "playwright": {
            "type": "local",
            "command": ["npx", "@playwright/mcp@latest", "--browser", "chromium", "--caps", "vision"],
            "enabled": true
        }
    },
    "command": {
        "build" : {
            "template": "Go. $ARGUMENTS",
            "description": "Run build without switching to build agent",
            "agent": "build"
        }
    }
}
